# code-docs configuration
# Copy this file to .env and adjust for your system

# Directory containing source code projects with .md files
CODE_DIR="$HOME/Documents/code"

# Directory where generated HTML docs will be written
OUTPUT_DIR="$HOME/Documents/code-html"

# Additional PATH entries (e.g. Homebrew bin directory)
# Apple Silicon: /opt/homebrew/bin
# Intel Mac:     /usr/local/bin
# Linux:         (leave empty or omit)
EXTRA_PATH="/opt/homebrew/bin"

# Projects to exclude from documentation (space-separated directory names)
# Example: EXCLUDE_PROJECTS="archived-project fork-of-something"
EXCLUDE_PROJECTS=""

# Sidebar display style: "flat" (file paths as flat links) or "tree" (nested folders)
# Default: tree
SIDEBAR_STYLE="tree"
